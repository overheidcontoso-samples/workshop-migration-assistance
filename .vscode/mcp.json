{
    "servers": {
        "context7": {
            "type": "http",
            "url": "https://mcp.context7.com/mcp"
        },
        "microsoft-docs": {
            "type": "http",
            "url": "https://learn.microsoft.com/api/mcp"
        },
        "filesystem": {
            "type": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "./migrations"
            ]
        },
        "git": {
            "type": "stdio",
            "command": "uvx",
            "args": [
                "mcp-server-git",
                "--repository",
                "."
            ]
        }
        
    }
}